# test.cfg — Development configuration for CoreSDK
# ---------------------------------------------------
# Automatically used by Core_Init() when the binary placeholders 
# have not been injected (e.g., local build in WSL).
#
# DO NOT use in production. DO NOT commit with real credentials.
# Add to .gitignore if it contains sensitive data.
#
# NOTE: In this GitHub example, 'serial' and 'key' fields can be left 
# empty, as this library build is compiled in 'test mode' and utilizes 
# a pre-configured authentication mechanism for development.
#
# Format: key=value (no spaces around =, no quotes)

#serial_number=
#device_key=
log_path=access_log.txt
rpc_url=https://rpc.matrix.blockchain.enjin.io
ca_bundle_path=certs/cacert.pem
collection_id=3333
token_id_override=001
default_pin=123456
